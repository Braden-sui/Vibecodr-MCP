PORT=3000
APP_BASE_URL=http://localhost:3000
VIBECDR_API_BASE=https://api.vibecodr.space
SESSION_SIGNING_KEY=replace_with_long_random_secret_min_32_chars
COOKIE_SECURE=false
ALLOW_MANUAL_TOKEN_LINK=false

ENABLE_CODEX_IMPORT_PATH=true
ENABLE_CHATGPT_IMPORT_PATH=true
ENABLE_PUBLISH_FROM_CHATGPT=true
MAX_REQUEST_BODY_BYTES=1500000
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_REQUESTS_PER_WINDOW=240
RATE_LIMIT_MCP_REQUESTS_PER_WINDOW=120

# OAuth provider settings (Clerk OAuth app)
OAUTH_PROVIDER_NAME=clerk
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_SCOPES=openid profile email offline_access
OAUTH_REDIRECT_URI=
OAUTH_AUDIENCE=

# Option A (recommended): issuer/discovery-based endpoint resolution
OAUTH_ISSUER_URL=
OAUTH_DISCOVERY_URL=

# Option B: explicit endpoint URLs
OAUTH_AUTHORIZATION_URL=
OAUTH_TOKEN_URL=

# Optional preregistered MCP client for an official public CLI
MCP_STATIC_CLIENT_ID=
MCP_STATIC_CLIENT_SECRET=
MCP_STATIC_CLIENT_REDIRECT_URIS=
